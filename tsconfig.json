{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "target": "es2018",
    "moduleResolution": "bundler",
    "composite": true,
    "tsBuildInfoFile": "./tmp/tsconfig.build.tsbuildinfo",
    "declarationMap": false,
    "outDir": "tmp/dist",
    "strict": true,
    "noEmit": true,
    "lib": [
      "ES2020"
    ]
  }
}
