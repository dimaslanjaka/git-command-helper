#!/bin/sh
set -e

npx -y lint-staged

# Generate composite run-tests action and stage it for commit (skip on CI)
if [ -z "$GITHUB_ACTIONS" ] && [ -z "$CI" ]; then
  npx -y generate-test-ci
  git add .github/workflows/test.yml
else
  echo "CI environment detected — skipping generate-test-ci"
fi

# Generate composite workflow and stage it for commit
npx generate-ci
if [ -n "$GITHUB_ACTIONS" ] || [ -n "$CI" ]; then
  echo "CI environment detected — skipping git add of generated action"
else
  git add .github/workflows/test.yml .github/actions/setup-environments/action.yml .github/workflows/build-release.yml
fi

# Check tarballs under 10MB
check_tarballs() {
  dir="$1"
  if [ -d "$dir" ]; then
    for file in "$dir"/*.tgz; do
      [ -e "$file" ] || continue
      size_bytes=$(wc -c <"$file")
      if [ "$size_bytes" -gt $((10 * 1024 * 1024)) ]; then
        echo "Error: Tarball $file exceeds 10MB limit"
        exit 1
      fi
    done
  fi
}

check_tarballs release
check_tarballs releases
