{
  "emmet.includeLanguages": {
    "ejs": "html"
  },
  "terminal.integrated.env.linux": {
    "PATH": "/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/usr/games:/usr/local/games:/usr/lib/wsl/lib:${workspaceFolder}/bin:${workspaceFolder}/node_modules/.bin:${workspaceFolder}/vendor/bin",
    "PUPPETEER_SKIP_DOWNLOAD": "true",
    "PHP_CS_FIXER_IGNORE_ENV": "1",
    "ESLINT_USE_FLAT_CONFIG": "true"
  },
  "terminal.integrated.env.windows": {
    "PATH": "${env:LOCALAPPDATA}\\nvm;C:\\nvm4w\\nodejs;C:\\Program Files\\Git\\cmd;C:\\Program Files\\Git\\usr\\bin;${env:PATH};${workspaceFolder}\\node_modules\\.bin;${workspaceFolder}\\bin;${workspaceFolder}\\vendor\\bin;C:\\laragon\\bin\\mysql\\mysql-8.4.3-winx64\\bin;C:\\Users\\Dell\\AppData\\Local\\Programs\\Ollama",
    "PUPPETEER_SKIP_DOWNLOAD": "true",
    "PHP_CS_FIXER_IGNORE_ENV": "1",
    "ESLINT_USE_FLAT_CONFIG": "true"
  },
  "terminal.integrated.defaultProfile.windows": "Short PowerShell",
  "terminal.integrated.profiles.windows": {
    "Cygwin": {
      "args": ["--login", "-i"],
      "env": {
        "CHERE_INVOKING": "1"
      },
      "path": "C:\\cygwin64\\bin\\bash.exe"
    },
    "Short Command Prompt": {
      "path": ["${env:windir}\\System32\\cmd.exe"],
      "args": ["/k", "prompt $g", "prompt $p$_$g"],
      "icon": "terminal-cmd"
    },
    "Command Prompt": {
      "args": [],
      "icon": "terminal-cmd",
      "path": ["${env:windir}\\Sysnative\\cmd.exe", "${env:windir}\\System32\\cmd.exe"]
    },
    "Git Bash": {
      "source": "Git Bash"
    },
    "PowerShell": {
      "icon": "terminal-powershell",
      "source": "PowerShell"
    },
    "Short PowerShell": {
      "source": "PowerShell",
      "args": ["-NoExit", "-Command", "function prompt { \"[$((Get-Item .).Name)]> \" }"],
      "icon": "terminal-powershell"
    }
  },
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "never",
    "source.fixAll.ts": "never",
    "source.addMissingImports.ts": "never",
    "source.removeUnused.ts": "never",
    "source.removeUnusedImports": "never",
    "source.sort.json": "never",
    "source.sortImports": "never"
  },
  "editor.formatOnSave": false,
  "git.enabled": true,
  "code-runner.clearPreviousOutput": true,
  "code-runner.saveFileBeforeRun": true,
  "code-runner.saveAllFilesBeforeRun": true,
  "code-runner.runInTerminal": true,
  "files.exclude": {
    "**/dist": false,
    "**/node_modules": true,
    "**/vendor": true
  },
  "code-runner.respectShebang": true,
  "code-runner.executorMapByGlob": {
    "*.test.{ts,cjs,mjs}": "npm test -- --testPathPatterns=\"$fileName\""
  },
  "eslint.codeActionsOnSave.mode": "all",
  "workbench.localHistory.exclude": {
    "**dist/**": true
  },
  "search.exclude": {
    "**/dist/**": true
  },
  "eslint.useFlatConfig": true,
  "git.autoStash": true,
  "eslint.probe": [
    "astro",
    "civet",
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "html",
    "mdx",
    "vue",
    "markdown",
    "json",
    "jsonc",
    "css",
    "glimmer-js",
    "glimmer-ts",
    "svelte",
    "nunjucks"
  ],
  "eslint.validate": [
    "astro",
    "civet",
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "html",
    "mdx",
    "vue",
    "markdown",
    "json",
    "jsonc",
    "css",
    "glimmer-js",
    "glimmer-ts",
    "svelte",
    "nunjucks"
  ]
}
